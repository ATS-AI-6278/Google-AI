{
  "name": "google-ai-studio-manager",
  "version": "1.0.0",
  "description": "Google AI Studio model management and analytics dashboard",
  "main": "index.html",
  "scripts": {
    "dev": "npx concurrently \"npm run start:backend\" \"live-server --port=3000 --host=localhost --ignore=node_modules\"",
    "start:backend": "node server.js",
    "build": "echo 'Build complete'",
    "start": "npm run dev"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "lucide": "^0.294.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "live-server": "^1.2.2",
    "node-fetch": "^2.7.0"
  },
  "keywords": [
    "google-ai",
    "analytics",
    "model-management"
  ],
  "author": "Your Name",
  "license": "MIT"
}
